# -- Database -----------------------------------------------------------------
# SQLite (default, no setup needed for local dev):
DATABASE_URL=sqlite:///./vigilyx.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/vigilyx

# -- API server ---------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000

# -- Auth (JWT) ---------------------------------------------------------------
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-use-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# -- Encryption ---------------------------------------------------------------
# Fernet key used to encrypt Stripe API keys at rest in the database.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: back this up — if you lose the key, all stored Stripe keys become unreadable.
FERNET_KEY=changeme-generate-a-real-fernet-key

# -- Anomaly detection --------------------------------------------------------
MAD_THRESHOLD=3.5
ZSCORE_THRESHOLD=2.5
ROLLING_WINDOW_DAYS=30

# -- Ingestion ----------------------------------------------------------------
INGESTION_LOOKBACK_DAYS=90
BASE_CURRENCY=usd
SCHEDULER_INTERVAL_HOURS=24

# -- Frontend (Next.js) -------------------------------------------------------
# Copy this line into frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8000
