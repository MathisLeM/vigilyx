# -- Environment ---------------------------------------------------------------
# Set to "production" to enable strict security checks and disable API docs.
ENVIRONMENT=development

# -- Database -----------------------------------------------------------------
# SQLite (default, no setup needed for local dev):
DATABASE_URL=sqlite:///./vigilyx.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/vigilyx

# -- API server ---------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000

# -- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# Dev default: localhost. Set your prod domain here in production.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example:
# ALLOWED_ORIGINS=https://app.vigilyx.com

# -- Auth (JWT) ---------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production — startup will fail if still set to the placeholder.
SECRET_KEY=changeme-use-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# -- Encryption ---------------------------------------------------------------
# Fernet key used to encrypt Stripe and Slack credentials at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: back this up — losing it makes all stored keys unreadable.
# REQUIRED in production — startup will fail if not set.
FERNET_KEY=changeme-generate-a-real-fernet-key

# -- Anomaly detection --------------------------------------------------------
MAD_THRESHOLD=3.5
ZSCORE_THRESHOLD=2.5
ROLLING_WINDOW_DAYS=30

# -- Ingestion ----------------------------------------------------------------
INGESTION_LOOKBACK_DAYS=90
BASE_CURRENCY=usd
SCHEDULER_INTERVAL_HOURS=24

# -- Frontend (Next.js) -------------------------------------------------------
# Copy this line into frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8000
